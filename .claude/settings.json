{
  "permissions": {
    "allow": [
      "Bash(/c/Users/victurib/AppData/Roaming/Python/Python313/Scripts/graphify.exe install:*)",
      "Bash(python -c ':*)",
      "Bash(python -c \"import graphifyy; import inspect; print\\(inspect.getfile\\(graphifyy\\)\\)\")",
      "Bash(python -c \"import graphifyy; print\\(dir\\(graphifyy\\)\\)\")",
      "Bash(python -c \"import graphify; print\\(dir\\(graphify\\)\\)\")",
      "Bash(grep -v \"\\\\.ts$\\\\|\\\\.tsx$\\\\|\\\\.js$\\\\|\\\\.jsx$\\\\|\\\\.py$\\\\|\\\\.ps1$\")",
      "Bash(/c/Users/victurib/AppData/Roaming/Python/Python313/Scripts/graphify.exe query:*)",
      "Bash(grep -v \"^$\")",
      "Bash(npx supabase:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
